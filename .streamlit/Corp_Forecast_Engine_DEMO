                    prior_total = 0 if pd.isna(prior_total) else prior_total
                    
                    row.append(budget_total)
                    row.append(prior_total)
                    
                    # YoY Growth
                    yoy_growth = ((account_total / prior_total) - 1) if prior_total > 0 else 0
                    row.append(yoy_growth)
                    
                    category_budget += budget_total
                    category_prior += prior_total
                
                if account_total != 0:
                    rows.append(row)
            
            # Category total
            total_row = [f"Total {section_title}"]
