    def get_actual_amount(self, year, gl_code, month=None):
        """Get actual amount from trial balance"""
        
        # Check if this GL should be excluded
        if self.exclude_legal and gl_code == 51451:
            return 0
        if self.exclude_depreciation and gl_code == 60100:
            return 0
        
        if year not in self.corp_trial_balance:
            return 0
        
        df = self.corp_trial_balance[year]
        account_data = df[df['Account'] == gl_code]
        
        if account_data.empty:
            return 0
        
        total_amount = 0
        
        for idx, row in account_data.iterrows():
            account_type = row.get('Type', 'Expense')
            
            if month is not None:
                # Single month
                if month < 1 or month > 12:
                    continue
                month_col = self.month_cols[month - 1]
                
                if month_col in row:
                    value = row[month_col]
                    if pd.notna(value):
                        if account_type == 'Income':
                            total_amount += abs(float(value))
                        else:
                            total_amount += float(value)
            else:
                # YTD calculation
                row_ytd = 0
                months_to_sum = min(self.current_month, 12) if year == self.current_year else 12
                
                for m in range(months_to_sum):
                    month_col = self.month_cols[m]
                    if month_col in row:
                        value = row[month_col]
                        if pd.notna(value):
                            row_ytd += float(value)
                
                if account_type == 'Income':
                    total_amount += abs(row_ytd)
                else:
                    total_amount += row_ytd
        
        return total_amount

    def get_budget_amount(self, gl_code, year, month=None):
        """Get budget amount"""
        gl_code = int(gl_code) if not isinstance(gl_code, int) else gl_code
        
        if gl_code in self.budget_data:
            budget_row = self.budget_data[gl_code]
            
            if month is not None:
                if month < 1 or month > 12:
                    return 0
                budget_col = self.budget_month_cols[month - 1]
                value = budget_row.get(budget_col, 0)
                return float(value) if pd.notna(value) else 0
            else:
                # YTD budget
                total = 0
                months = min(self.current_month, 12) if year == self.current_year else 12
                for m in range(months):
                    budget_col = self.budget_month_cols[m]
                    value = budget_row.get(budget_col, 0)
                    if pd.notna(value):
                        total += float(value)
                return total
        return 0

    def get_active_hotels(self, as_of_date, include_pipeline=True):
        """Get active hotels as of date - CONSOLIDATED VERSION
        
        Args:
            as_of_date: Date to check hotel status
            include_pipeline: If True, includes pipeline hotels that have started
                            If False, only returns existing active hotels
        """
        if 'hotel_master' not in self.data:
            return pd.DataFrame()
        
        hotels = self.data['hotel_master']
        
        # Handle missing Status column gracefully (for backward compatibility)
        if 'Status' not in hotels.columns:
            # Fallback for old data structure
            return hotels[
                (hotels['Start_Date'] <= as_of_date) &
                ((hotels['End_Date'].isna()) | (hotels['End_Date'] >= as_of_date))
            ].copy()
        
        # Build filter conditions
        conditions = []
        
        # Active hotels
        active_condition = (
            (hotels['Status'] == self.HOTEL_STATUS['ACTIVE']) &
            (hotels['Start_Date'] <= as_of_date) &
            ((hotels['End_Date'].isna()) | (hotels['End_Date'] >= as_of_date))
        )
        conditions.append(active_condition)
        
        # Pipeline hotels if requested
        if include_pipeline:
            pipeline_condition = (
                (hotels['Status'].isin(self.PIPELINE_STATUSES)) &
                (hotels['Start_Date'] <= as_of_date)
            )
            conditions.append(pipeline_condition)
        
        # Combine conditions with OR logic
        combined_condition = conditions[0]
        for condition in conditions[1:]:
            combined_condition = combined_condition | condition
        
        return hotels[combined_condition].copy()
        
        # Get existing active hotels
        if 'hotel_master' in self.data:
            hotels = self.data['hotel_master']
            existing = hotels[
                (hotels['Start_Date'] <= as_of_date) &
                ((hotels['End_Date'].isna()) | (hotels['End_Date'] >= as_of_date)) &
                (hotels.get('Status', 'Active') != 'Terminated')
            ].copy()
            existing['Source'] = 'Existing'
            active_hotels.append(existing)
        
        # Add future pipeline hotels that have started
        if 'future_pipeline' in self.data:
            pipeline = self.data['future_pipeline']
            
            # Filter by Expected_Start_Date and Pipeline_Status
            # Hotels starting on or before the date should be included
            # This matches the logic for existing hotels
            future_active = pipeline[
                (pipeline['Expected_Start_Date'] <= as_of_date) &  # Use <= to match existing hotel logic
                ((pipeline['Pipeline_Status'].isin(['Confirmed', 'Under Contract', 'In Development'])) |
                 (pipeline['Pipeline_Status'].isna()))  # Include NaN status for now
            ].copy()
            
            # Mark these as pipeline hotels
            future_active['Source'] = 'Pipeline'
            
            # Map pipeline column names to match existing hotel columns
            column_mapping = {
                'Planned_Property_ID': 'Property_ID',
                'Planned_Property_Name': 'Hotel_Name',
                'Planned_Brand': 'Brand',
                'Planned_Key_Count': 'Key_Count',
                'Expected_Start_Date': 'Start_Date',
                'Planned_Location_City': 'City',
                'Planned_Location_State': 'State'
            }
            
            future_active = future_active.rename(columns=column_mapping)
            
            # Also map fee columns if they exist
            fee_mapping = {
                'Base_Management_Fee_Percent': 'Base_Management_Fee_Percent',
                'Accounting_Fee_Monthly': 'Accounting_Fee_Monthly',
                'Revenue_Management_Fee_Monthly': 'Revenue_Management_Fee_Monthly',
                'Expected_Annual_Revenue': 'Expected_Annual_Revenue'
            }
            
            for old_col, new_col in fee_mapping.items():
                if old_col in pipeline.columns and old_col not in future_active.columns:
                    future_active[new_col] = pipeline[old_col]
            
            if len(future_active) > 0:
                active_hotels.append(future_active)
        
        # Combine all active hotels
        if active_hotels:
            combined = pd.concat(active_hotels, ignore_index=True)
            return combined
        
        return pd.DataFrame()

    def get_active_employees(self, as_of_date):
        """Get active employee count as of date, including allocated employees"""
        if not isinstance(as_of_date, pd.Timestamp):
            as_of_date = pd.to_datetime(as_of_date)
        
        total_count = 0
        
        # Count full-time employees
        if 'payroll' in self.data:
            payroll = self.data['payroll']
            for _, emp in payroll.iterrows():
                start_date = pd.to_datetime(emp.get('Start_Date')) if pd.notna(emp.get('Start_Date')) else pd.to_datetime('2000-01-01')
                end_date = pd.to_datetime(emp.get('End_Date')) if pd.notna(emp.get('End_Date')) else pd.to_datetime('2099-12-31')
                
                if start_date <= as_of_date <= end_date:
                    total_count += 1
        
        # Count allocated employees (they're additional headcount)
        if 'allocated_employees' in self.data:
            allocated_df = self.data['allocated_employees']
            for _, emp in allocated_df.iterrows():
                start_date = pd.to_datetime(emp.get('Start_Date')) if pd.notna(emp.get('Start_Date')) else pd.to_datetime('2000-01-01')
                end_date = pd.to_datetime(emp.get('End_Date')) if pd.notna(emp.get('End_Date')) else pd.to_datetime('2099-12-31')
                
                if start_date <= as_of_date <= end_date:
                    # Only count if they have an allocation amount > 0
                    if 'Allocated_Amount_Corporate_Fixed' in emp and pd.notna(emp.get('Allocated_Amount_Corporate_Fixed')):
                        if float(emp.get('Allocated_Amount_Corporate_Fixed', 0)) > 0:
                            total_count += 1
        
        # Add corporate employees from pipeline hotels that have started
        if 'hotel_master' in self.data:
            hotels = self.data['hotel_master']
            
            if 'Status' in hotels.columns:
                pipeline_started = hotels[
                    (hotels['Status'].isin(self.PIPELINE_STATUSES)) &
                    (hotels['Start_Date'] <= as_of_date)
                ]
            else:
                pipeline_started = pd.DataFrame()
            
            for _, hotel in pipeline_started.iterrows():
                corp_additions = float(hotel.get('Corporate_Employee_Addition', 0)) if pd.notna(hotel.get('Corporate_Employee_Addition')) else 0
                total_count += corp_additions
        
        return total_count


