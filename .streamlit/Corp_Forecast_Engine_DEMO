        rows = []
        header = ['Account'] + self.month_cols + [f'Total {target_year}']
        
        if target_year == self.current_year:
            header.extend([f'Budget {target_year}', f'Actual {target_year - 1}', 'YoY Growth %'])
        
        rows.append([f'{target_year} ANNUAL FORECAST'])
        rows.append([''])
        rows.append(header)
        
        # Add hotel count row
        hotel_count_row = ['Active Hotels']
        for month in range(1, 13):
