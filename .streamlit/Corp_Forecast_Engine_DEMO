def validate_expense_forecasts(engine):
    """
    Comprehensive validation of expense forecasting for 2025-2027
    Identifies which expenses are properly configured and which are missing data
    """
    print("\n" + "="*80)
    print("EXPENSE FORECAST VALIDATION REPORT")
    print("="*80)
    
    if 'expenses' not in engine.data or not engine.expense_logic:
        print("\n❌ CRITICAL: No expense data loaded!")
        return
    
    print(f"\nTotal GL codes configured: {len(engine.expense_logic)}")
    print(f"Current period: {engine.month_cols[engine.current_month-1]} {engine.current_year}")
    
    # Categorize expenses by type
    by_type = {
        'Fixed': [],
        'Variable': [],
        'Per_Hotel': [],
        'Per_Employee': [],
        'Mixed': []
    }
    
    for gl_code, logic in engine.expense_logic.items():
        expense_type = logic.get('type', 'Fixed')
        by_type[expense_type].append(gl_code)
    
    print("\n" + "-"*80)
    print("EXPENSE TYPE SUMMARY")
    print("-"*80)
    for exp_type, gl_codes in by_type.items():
        print(f"{exp_type:15s}: {len(gl_codes):3d} GL codes")
    
    # =========================================================================
    # SECTION 1: VARIABLE EXPENSES - These REQUIRE year-specific columns
    # =========================================================================
    print("\n" + "="*80)
    print("SECTION 1: VARIABLE EXPENSES (Require Year-Specific Data)")
    print("="*80)
    
    if by_type['Variable']:
        print(f"\nFound {len(by_type['Variable'])} Variable expense GL codes")
        print("\nVariable expenses MUST have columns like: Jan_2025, Feb_2025, Jan_2026, etc.")
        print("\n" + "-"*80)
        
        missing_year_plus1 = []
        missing_year_plus2 = []
        
        for gl_code in sorted(by_type['Variable']):
            logic = engine.expense_logic[gl_code]
            gl_name = None
            
            # Find GL name
            for section, gl_dict in engine.gl_mapping.items():
                if gl_code in gl_dict:
                    gl_name = gl_dict[gl_code]
                    break
            
            print(f"\nGL {gl_code}: {gl_name or 'Unknown'}")
            print(f"  Type: Variable")
            print(f"  Base Amount: ${logic.get('base_amount', 0):,.2f}")
            
            # Check year-specific data
            yearly_amounts = logic.get('yearly_amounts', {})
            
            for year in [engine.current_year, engine.current_year + 1, engine.current_year + 2]:
                if year in yearly_amounts:
                    months_count = len(yearly_amounts[year])
                    total = sum(yearly_amounts[year].values())
                    print(f"  ✓ {year}: {months_count} months configured, Total: ${total:,.2f}")
                else:
                    print(f"  ❌ {year}: NO DATA - Will use base_amount + CPI")
                    if year == engine.current_year + 1:
                        missing_year_plus1.append(f"GL {gl_code} ({gl_name})")
                    elif year == engine.current_year + 2:
                        missing_year_plus2.append(f"GL {gl_code} ({gl_name})")
            
            # Test calculation for each year
            print(f"\n  Sample Calculations:")
            for year in [engine.current_year, engine.current_year + 1, engine.current_year + 2]:
                jan_amount = engine.forecast_amount(year, gl_code, 1)
                jun_amount = engine.forecast_amount(year, gl_code, 6)
                dec_amount = engine.forecast_amount(year, gl_code, 12)
                annual = sum(engine.forecast_amount(year, gl_code, m) for m in range(1, 13))
                print(f"    {year}: Jan=${jan_amount:>10,.2f}  Jun=${jun_amount:>10,.2f}  Dec=${dec_amount:>10,.2f}  Annual=${annual:>12,.2f}")
    else:
        print("\nNo Variable expenses found.")
    
    # =========================================================================
    # SECTION 2: FIXED EXPENSES
    # =========================================================================
    print("\n" + "="*80)
    print("SECTION 2: FIXED EXPENSES (Base Amount + CPI)")
    print("="*80)
    
    if by_type['Fixed']:
        print(f"\nFound {len(by_type['Fixed'])} Fixed expense GL codes")
        print("\nShowing first 5 with non-zero amounts:")
        
        count = 0
        for gl_code in sorted(by_type['Fixed']):
            logic = engine.expense_logic[gl_code]
            if logic.get('base_amount', 0) == 0:
                continue
                
            count += 1
