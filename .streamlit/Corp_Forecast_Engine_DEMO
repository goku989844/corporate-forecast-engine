                    break
            
            print(f"\nGL {gl_code}: {gl_name or 'Unknown'}")
            print(f"  Base Amount: ${logic.get('base_amount', 0):,.2f}")
            
            # Test calculations
            for year in [engine.current_year, engine.current_year + 1, engine.current_year + 2]:
                jan_amount = engine.forecast_amount(year, gl_code, 1)
                annual = sum(engine.forecast_amount(year, gl_code, m) for m in range(1, 13))
                print(f"  {year}: ${jan_amount:>10,.2f}/month, ${annual:>12,.2f}/year")
    
    # =========================================================================
    # SECTION 3: OTHER TYPES
    # =========================================================================
    for exp_type in ['Per_Hotel', 'Per_Employee', 'Mixed']:
        if by_type[exp_type]:
            print(f"\n{exp_type.upper()} EXPENSES: {len(by_type[exp_type])} GL codes")
    
    # =========================================================================
    # SUMMARY
    # =========================================================================
    print("\n" + "="*80)
    print("SUMMARY & RECOMMENDATIONS")
    print("="*80)
    
    if missing_year_plus1 or missing_year_plus2:
        print("\n" + "!"*80)
        print("WARNING: Some Variable expenses missing year-specific data:")
        if missing_year_plus1:
            print(f"\n  Missing {engine.current_year + 1} data:")
