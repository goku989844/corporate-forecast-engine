                left=Side(style='thin', color='D3D3D3'),
                right=Side(style='thin', color='D3D3D3'),
                top=Side(style='thin', color='D3D3D3'),
                bottom=Side(style='thin', color='D3D3D3')
            )
            
            # Apply formatting to each sheet
            for sheet_name in workbook.sheetnames:
                worksheet = workbook[sheet_name]
                
                # Set column widths
                worksheet.column_dimensions['A'].width = 35
                for col in range(2, worksheet.max_column + 1):
                    col_letter = get_column_letter(col)
                    worksheet.column_dimensions[col_letter].width = 15
                
                # Format headers (row 1)
                for cell in worksheet[1]:
                    if cell.value:
                        cell.font = header_font
                        cell.fill = header_fill
                        cell.alignment = header_alignment
                        cell.border = thin_border
                
                # Apply number formatting to all data cells
                for row_idx, row in enumerate(worksheet.iter_rows(min_row=2, max_row=worksheet.max_row), start=2):
                    for col_idx, cell in enumerate(row, start=1):
                        cell.border = thin_border
                        
                        if col_idx == 1:
                            continue
                        
                        header_cell = worksheet.cell(1, col_idx)
                        header_text = str(header_cell.value) if header_cell.value else ''
                        
                        account_cell = worksheet.cell(row_idx, 1)
                        account_text = str(account_cell.value) if account_cell.value else ''
                        
                        if isinstance(cell.value, (int, float)) and cell.value != '':
                            is_percentage = False
                            
                            # EXECUTIVE SCORECARD SPECIFIC RULES (most specific first)
                            if sheet_name == 'Executive Scorecard':
                                # Check account text for percentage indicators
                                if any(keyword in account_text for keyword in [
                                    'Margin %', 'Revenue at Risk', 'Turnover', '% of Revenue',
                                    'vs Target', 'vs Budget', 'vs Prior', 'Growth', 'Change'
                                ]):
                                    if 0 <= abs(cell.value) <= 1:
                                        is_percentage = True
                                # Column-specific: columns 3-5 often contain percentages in scorecard
                                elif col_idx >= 3 and 0 <= abs(cell.value) <= 1:
                                    # Look for context in surrounding cells
                                    row_values = [str(worksheet.cell(row_idx, c).value or '') for c in range(1, 6)]
                                    if any(keyword in ' '.join(row_values) for keyword in 
                                        ['Target', 'Budget', 'Prior', 'Growth', 'Change', 'Risk', 'Margin']):
                                        is_percentage = True
                            
                            # GROWTH ANALYSIS DASHBOARD SPECIFIC RULES
                            elif sheet_name == 'Growth Analysis':
                                if 'Growth %' in account_text or 'Contribution' in account_text:
                                    is_percentage = True
                                elif col_idx == 3 and 0 <= abs(cell.value) <= 1:  # Growth % column
                                    is_percentage = True
                            
                            # RISK DASHBOARD SPECIFIC RULES  
                            elif sheet_name == 'Risk Dashboard':
                                if any(keyword in account_text for keyword in [
                                    'Current %', 'Target %', '% of Total', 'Risk Level',
                                    'Top 1 Owner', 'Top 3 Owner', 'Top 5 Owner',
                                    'Expiring', 'Turnover'
                                ]):
                                    if 0 <= abs(cell.value) <= 1:
                                        is_percentage = True
                                elif col_idx in [2, 3] and 0 <= abs(cell.value) <= 1:  # Current % and Target % columns
                                    row_values = [str(worksheet.cell(row_idx, c).value or '') for c in range(1, 5)]
                                    if any(keyword in ' '.join(row_values) for keyword in ['Risk', 'Owner', 'Expiring']):
                                        is_percentage = True
                            
                            # GENERAL HEADER-BASED DETECTION (fallback)
                            if not is_percentage:
                                if '%' in header_text:
                                    is_percentage = True
                                elif 'Percent' in header_text or 'Margin' in header_text:
                                    is_percentage = True
                                elif 'Var %' in header_text or 'YoY %' in header_text or 'Growth %' in header_text:
                                    is_percentage = True
                            
                            # ACCOUNT NAME DETECTION (fallback)
                            if not is_percentage:
                                if 'Margin' in account_text and '%' in account_text:
                                    is_percentage = True
                                elif '% of Total' in account_text or '% of Revenue' in account_text:
                                    is_percentage = True
                            
                            # KPI Dashboard specific (existing code)
                            if not is_percentage and sheet_name == 'KPI Dashboard':
                                if 0 < cell.value <= 1 and col_idx >= 6:
                                    is_percentage = True
                            
                            # Apply formatting
                            if is_percentage:
                                cell.number_format = '0.0%'
                            else:
                                cell.number_format = '#,##0'
                
                # Make total rows bold
                for row in worksheet.iter_rows(min_row=2, max_row=worksheet.max_row):
                    if row[0].value and ('Total' in str(row[0].value) or 'EBITDA' in str(row[0].value) or 'NOI' in str(row[0].value)):
                        for cell in row:
                            cell.font = Font(bold=True)
                
                # Freeze panes
                worksheet.freeze_panes = 'B2'
        
        print(f"  Export complete: {filename}")
        return filename

