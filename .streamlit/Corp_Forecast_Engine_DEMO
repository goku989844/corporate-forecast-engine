            for _, emp in payroll.iterrows():
                # Check status
                status = emp.get('Status', 'Active')
                if pd.notna(status) and str(status).strip().upper() not in ['ACTIVE', '']:
                    continue
                
                start_date = pd.to_datetime(emp.get('Start_Date')) if pd.notna(emp.get('Start_Date')) else pd.to_datetime('2000-01-01')
                end_date = pd.to_datetime(emp.get('End_Date')) if pd.notna(emp.get('End_Date')) else pd.to_datetime('2099-12-31')
                
                if start_date <= month_end and end_date >= month_date:
                    other_benefits = float(emp.get('Other_Benefits_Monthly', 0)) if pd.notna(emp.get('Other_Benefits_Monthly')) else 0
                    dental_vision = float(emp.get('Dental_Vision_Monthly', 0)) if pd.notna(emp.get('Dental_Vision_Monthly')) else 0
                    life_insurance = float(emp.get('Life_Insurance_Monthly', 0)) if pd.notna(emp.get('Life_Insurance_Monthly')) else 0
                    disability = float(emp.get('Disability_Insurance_Monthly', 0)) if pd.notna(emp.get('Disability_Insurance_Monthly')) else 0
                    hsa = float(emp.get('HSA_Contribution_Monthly', 0)) if pd.notna(emp.get('HSA_Contribution_Monthly')) else 0
                    parking = float(emp.get('Parking_Transportation_Monthly', 0)) if pd.notna(emp.get('Parking_Transportation_Monthly')) else 0
                    
                    total_benefits += other_benefits + dental_vision + life_insurance + disability + hsa + parking
            return total_benefits
        
        # Vacation Pay (50403)
        elif gl_code == 50403:
            return 0
        
        # For other payroll GLs not specifically handled
        else:
            return 0
    
    def forecast_amount(self, year, gl_code, month):
        """Forecast amount for future periods"""

        # Check if this GL should be excluded
        if self.exclude_legal and gl_code == 51451:
            return 0
        if self.exclude_depreciation and gl_code == 60100:
            return 0
        
        # CRITICAL FIX: For historical years, ALWAYS use actual data
        if year < self.current_year:
            return self.get_actual_amount(year, gl_code, month)
        
        # For current year actuals, use actual data
        if year == self.current_year and month <= self.current_month:
            actual = self.get_actual_amount(year, gl_code, month)
            if actual != 0:
                return actual
        
        # Special handling for revenue accounts (ONLY for forecast periods)
        if gl_code == 40000:  # Management Fee Revenue
            return self.calculate_management_fee_revenue(year, month)
        elif gl_code == 40030:  # Accounting Fee Revenue
            return self.calculate_accounting_fee_revenue(year, month)
        elif gl_code == 40040:  # Revenue Management Fee
            return self.calculate_revenue_mgmt_fee(year, month)
        elif gl_code == 40020:  # Technical Service Fee
            return self.calculate_tech_service_fee(year, month)
        elif gl_code == 40010:  # Incentive Mgmt Fee Revenue
            return self.calculate_incentive_fee_revenue(year, month)
        
        # Special handling for payroll-related accounts
        payroll_gls = [
            *range(50000, 9002122),  # Includes 50121 Regional Allocation
            50195,  # Contract Labor
            50200,  # Bonus & Incentives
            50250,  # Payroll Taxes
            50300,  # Workers Compensation
            50303,  # 401K Employer Match
            50304,  # Health Ins - Employee Contrib
            50306,  # Health Insurance
            50400,  # Employee Benefits
            50403,  # Vacation Pay
        ]
    
        if gl_code in payroll_gls:
            # Use actual data for current year through current month
            if year == self.current_year and month <= self.current_month:
                actual = self.get_actual_amount(year, gl_code, month)
                if actual != 0:
                    return actual
                elif gl_code == 50121:
                    return self.calculate_payroll_expense(year, month, gl_code)
            # Calculate from payroll data for forecast months
            return self.calculate_payroll_expense(year, month, gl_code)
        
        # Check for manual forecast override
        if gl_code in self.expense_logic:
            logic = self.expense_logic[gl_code]
            
            if year in logic.get('manual_forecasts', {}):
                if month in logic['manual_forecasts'][year]:
                    return logic['manual_forecasts'][year][month]
        
        # FIXED: Get base amount from expense_logic configuration FIRST
        base = 0
        use_configured_base = False
        
        if gl_code in self.expense_logic:
            logic = self.expense_logic[gl_code]
            
            # Priority 1: If expense_logic has a configured base_amount, use it
            if 'base_amount' in logic and logic['base_amount'] > 0:
                base = logic['base_amount']
                use_configured_base = True
            # Priority 2: If it's a Per_Hotel type, calculate based on hotel count
            elif logic.get('type') == 'Per_Hotel' and logic.get('per_hotel', 0) > 0:
                month_date = datetime(year, month, 1)
                hotels = self.get_active_hotels(month_date)
                base = logic['per_hotel'] * len(hotels)
                use_configured_base = True
            # Priority 3: If it's a Per_Employee type, calculate based on employee count
            elif logic.get('type') == 'Per_Employee' and logic.get('per_employee', 0) > 0:
                month_date = datetime(year, month, 1)
                employee_count = self.get_active_employees(month_date)
                base = logic['per_employee'] * employee_count
                use_configured_base = True
        
        # Only use actual data if no configured base amount
        if not use_configured_base:
            if year == self.current_year:
                base = self.get_actual_amount(year, gl_code, self.current_month)
            else:
                # For future years, use average of current year
                current_year_total = 0
                for m in range(1, 13):
                    if m <= self.current_month:
                        current_year_total += self.get_actual_amount(self.current_year, gl_code, m)
                    else:
                        current_year_total += self.forecast_amount(self.current_year, gl_code, m)
                base = current_year_total / 12
        
        base = 0 if pd.isna(base) else base
        
        # Apply escalation based on expense type
        if gl_code in self.expense_logic:
            logic = self.expense_logic[gl_code]
            
            if logic['type'] == 'Variable':
                # Handle Variable expenses with year-specific amounts
                base_amount = 0
                
                # First check for year-specific amounts in yearly_amounts
                if 'yearly_amounts' in logic and year in logic['yearly_amounts']:
                    month_key = self.month_cols[month - 1]  # Convert month number to month name
                    if month_key in logic['yearly_amounts'][year]:
                        base_amount = logic['yearly_amounts'][year][month_key]
                    else:
                        # This year exists but this specific month is missing
                        base_amount = logic.get('base_amount', 0)
                else:
                    # No year-specific data, use base amount
                    base_amount = logic.get('base_amount', 0)
                    
                    # Apply seasonal pattern if defined (optional)
                    if 'seasonal_pattern' in logic:
                        seasonal_factor = logic['seasonal_pattern'][month - 1] if month <= 12 else 1.0
                        base_amount = base_amount * seasonal_factor
                    
                    # Apply CPI only if we don't have specific year data
                    if year > self.current_year:
                        years_diff = year - self.current_year
                        base_amount = base_amount * (1.03 ** years_diff)
                
                return base_amount
            
            elif logic['type'] == 'Per_Employee':
                month_date = datetime(year, month, 1)
                employee_count = self.get_active_employees(month_date)
                amount = logic.get('per_employee', 100) * employee_count
                
                # Apply CPI for future years
                if year > self.current_year:
                    years_diff = year - self.current_year
                    amount = amount * (1.03 ** years_diff)  # ✅ Multiply 'amount'
                                    
                return amount
            
            elif logic['type'] == 'Per_Hotel':
                month_date = datetime(year, month, 1)
                hotels = self.get_active_hotels(month_date)
                amount = logic.get('per_hotel', 1000) * len(hotels)
                
                # Apply CPI for future years
                if year > self.current_year:
                    years_diff = year - self.current_year
                    amount = amount * (1.03 ** years_diff)  # ✅ Multiply 'amount'
                
                return amount
            
            elif logic['type'] == 'Mixed':
                month_date = datetime(year, month, 1)
                hotels = self.get_active_hotels(month_date)
                fixed = logic.get('base_amount', 0)
                variable = logic.get('per_hotel', 0) * len(hotels)
                total = fixed + variable
                
                # Apply CPI for future years
                if year > self.current_year:
                    years_diff = year - self.current_year
                    total = total * (1.03 ** years_diff)  # ✅ Multiply 'total'
                
                return total
            
            elif logic['type'] == 'Mixed_Employee':
                # NEW: Mixed_Employee type combines Fixed + Per_Employee components
                month_date = datetime(year, month, 1)
                employee_count = self.get_active_employees(month_date)
                fixed = logic.get('base_amount', 0)
                variable = logic.get('per_employee', 0) * employee_count
                total = fixed + variable
                
                # Apply CPI for future years
                if year > self.current_year:
                    years_diff = year - self.current_year
                    total = total * (1.03 ** years_diff)
                
                return total
            
            else:  # Fixed type (default)
                # For Fixed type, use the base amount (from config or actuals)
                # Apply CPI for future years
                if year == self.current_year:
                    return base
                else:
                    years_forward = year - self.current_year
                    return base * (1.03 ** years_forward)
        
        # Default escalation (for GL codes not in expense_logic)
        if year == self.current_year:
            return base
        else:
            years_forward = year - self.current_year
            return base * (1.03 ** years_forward)
        
