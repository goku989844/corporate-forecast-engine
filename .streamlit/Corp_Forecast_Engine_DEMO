            'noi_adjustments': {m: 0 for m in range(1, 13)}  # NEW
        }
        
        # GL codes that should be included in NOI calculation
        noi_below_ebitda_items = [60100, 60510, 60551, 60600, 60300]
        
        for category_name, gl_accounts in self.gl_mapping.items():
            section_title = self._format_section_title(category_name)
            rows.append([section_title] + [''] * (len(header) - 1))
            
            category_monthly = {m: 0 for m in range(1, 13)}
            category_budget = 0
            category_prior = 0
            
            for gl_code, account_name in sorted(gl_accounts.items()):
                row = [f"  {account_name}"]
                account_total = 0
                
                for month in range(1, 13):
                    if target_year == self.current_year and month <= self.current_month:
                        value = self.get_actual_amount(target_year, gl_code, month)
                    else:
                        value = self.forecast_amount(target_year, gl_code, month)
                    
                    value = 0 if pd.isna(value) else value
                    row.append(value)
                    account_total += value
                    category_monthly[month] += value
                    
                    if category_name == 'revenue':
                        grand_totals['revenue'][month] += value
                    elif category_name == 'payroll':
                        grand_totals['payroll'][month] += value
                        grand_totals['expenses'][month] += value
                    elif category_name == 'operating':
                        grand_totals['operating'][month] += value
                        grand_totals['expenses'][month] += value
                    elif category_name == 'non_operating':
                        grand_totals['expenses'][month] += value
                    elif category_name == 'below_ebitda':
                        grand_totals['expenses'][month] += value
                        # NEW: Track specific items for NOI
