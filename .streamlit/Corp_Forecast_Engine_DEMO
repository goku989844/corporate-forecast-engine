    def _detect_latest_month(self):
        """Automatically detect the latest month with actual data"""
        print("\n[AUTO-DETECTING LATEST ACTUAL PERIOD]")
        print("-" * 40)
        
        tb_files = glob.glob('INPUT_Trial_Balance_CORP_*.xlsx')
        
        if not tb_files:
            print("  WARNING: No trial balance files found")
            return None, None
        
        latest_year = 0
        latest_month = 0
        
        for file in tb_files:
            try:
                # Extract year from filename
                year_str = file.split('_')[-1].replace('.xlsx', '')
                year = int(year_str)
                
                # Load the file
                df = pd.read_excel(file, sheet_name='Trial_Balance_Data')
                corp_data = df[df['Property_ID'] == 900].copy()
                
                if len(corp_data) > 0:
                    # Initialize year in available_periods
                    if year not in self.available_periods:
                        self.available_periods[year] = []
                    
                    # Check each month for data
                    year_latest_month = 0
                    for month_idx, month_col in enumerate(self.month_cols):
                        if month_col in corp_data.columns:
                            # Check if there's any non-zero data in this month
                            month_data = corp_data[month_col]
                            if month_data.notna().any() and (month_data != 0).any():
                                self.available_periods[year].append(month_idx + 1)
                                year_latest_month = month_idx + 1
                                
                                if year > latest_year or (year == latest_year and month_idx + 1 > latest_month):
                                    latest_year = year
                                    latest_month = month_idx + 1
                    
                    if year_latest_month > 0:
                        print(f"  {year}: Found data through {self.month_cols[year_latest_month-1]}")
                    
            except Exception as e:
                print(f"  Error processing {file}: {e}")
        
        if latest_year > 0:
            self.current_year = latest_year
            self.current_month = latest_month
            print(f"\n  Latest actual period detected: {self.month_cols[latest_month-1]} {latest_year}")
            
            return latest_year, latest_month
        
        return None, None

