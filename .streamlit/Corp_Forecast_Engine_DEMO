                                for section in ['payroll', 'operating', 'non_operating']
                                for gl in self.gl_mapping[section].keys())
        ytd_budget_ebitda = ytd_budget_revenue - ytd_budget_expenses
        
        # Full year forecast
        fy_revenue = sum(self.get_actual_amount(self.current_year, gl, m) if m <= self.current_month 
                        else self.forecast_amount(self.current_year, gl, m)
                        for gl in self.gl_mapping['revenue'].keys()
