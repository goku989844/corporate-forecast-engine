    def get_hotel_revenue(self, property_id, year, month):
        """Get hotel revenue for a specific property and month"""
        if 'hotel_revenue' not in self.data:
            return 0
        
        property_id = int(property_id)
        month_name = self.month_cols[month - 1]
        hotel_rev_df = self.data['hotel_revenue']
        
        # Check if property exists
        if property_id not in hotel_rev_df['Property_ID'].values:
            return 0
        
        property_row = hotel_rev_df[hotel_rev_df['Property_ID'] == property_id]
        if property_row.empty:
            return 0
        
        # Try year-specific column first
        col_name = f"{month_name}_{year}_Hotel_Revenue"
        
        if col_name in hotel_rev_df.columns:
            revenue = property_row[col_name].values[0]
            if pd.notna(revenue):
                return float(revenue)
        
        # For future years without specific data, use current year as base and apply growth
        if year > self.current_year:
            base_col = f"{month_name}_{self.current_year}_Hotel_Revenue"
            if base_col in hotel_rev_df.columns:
                base_revenue = property_row[base_col].values[0]
                if pd.notna(base_revenue):
                    base_revenue = float(base_revenue)
                    # APPLY CPI/GROWTH for future years
                    years_diff = year - self.current_year
                    return base_revenue * (1.03 ** years_diff)
        
        # Try base column without year
        base_col = f"{month_name}_Hotel_Revenue"
        if base_col in hotel_rev_df.columns:
            revenue = property_row[base_col].values[0]
            if pd.notna(revenue):
                return float(revenue)
        
        return 0

    def calculate_management_fee_revenue(self, year, month):
        """Calculate management fee revenue including pipeline hotels"""
        
        # For actual months, use actual data
        if year == self.current_year and month <= self.current_month:
            actual = self.get_actual_amount(year, 40000, month)
            if actual != 0:
                return actual
        
        total_mgmt_fee = 0
        month_date = datetime(year, month, 1)
        
        # Get all active hotels including pipeline
        active_hotels = self.get_active_hotels(month_date)
        
        if active_hotels.empty:
            return 0
        
        for _, hotel in active_hotels.iterrows():
            property_id = int(hotel['Property_ID'])
            
            # Get management fee percentage
            mgmt_fee_pct = hotel.get('Base_Management_Fee_Percent', 0.03)
            if pd.isna(mgmt_fee_pct) or mgmt_fee_pct == 0:
                mgmt_fee_pct = 0.03
            
            # Handle revenue based on hotel status
            if 'Status' in hotel and hotel['Status'] in self.PIPELINE_STATUSES:
                # For pipeline hotels, use expected ANNUAL revenue
                if 'Expected_Annual_Revenue' in hotel and pd.notna(hotel['Expected_Annual_Revenue']):
                    annual_revenue = float(hotel['Expected_Annual_Revenue'])
                    
                    # Apply CPI for ALL future years (not just estimates)
                    if year > self.current_year:
                        years_diff = year - self.current_year
                        annual_revenue = annual_revenue * (1.03 ** years_diff)
                    
                    hotel_revenue = annual_revenue / 12  # Convert to monthly
                else:
                    # Estimate revenue based on hotel type and keys
                    keys = hotel.get('Key_Count', 100)
                    hotel_type = hotel.get('Hotel_Type', 'Select Service')
                    adr = self.adr_by_type.get(hotel_type, 100)
                    occupancy = 0.70  # 70% occupancy for new hotels
                    days_in_month = calendar.monthrange(year, month)[1]
                    hotel_revenue = keys * adr * occupancy * days_in_month
                    
                    # Apply CPI to estimated revenue
                    if year > self.current_year:
                        years_diff = year - self.current_year
                        hotel_revenue = hotel_revenue * (1.03 ** years_diff)
            else:
                # Get hotel revenue from forecast for existing hotels
                hotel_revenue = self.get_hotel_revenue(property_id, year, month)
                # Note: get_hotel_revenue should now handle CPI internally when using 2025 base data
                
                if hotel_revenue == 0:
                    # Estimate for missing properties
                    keys = hotel.get('Key_Count', 100)
                    adr = 100
                    occupancy = 0.70
                    days_in_month = calendar.monthrange(year, month)[1]
                    hotel_revenue = keys * adr * occupancy * days_in_month
                    
                    # Apply CPI to estimated revenue
                    if year > self.current_year:
                        years_diff = year - self.current_year
                        hotel_revenue = hotel_revenue * (1.03 ** years_diff)
            
            # Calculate management fee
            mgmt_fee = hotel_revenue * mgmt_fee_pct
            total_mgmt_fee += mgmt_fee
        
        return total_mgmt_fee
    
    def calculate_incentive_fee_revenue(self, year, month):
        """Calculate incentive management fee revenue from IMF forecast input"""
        
        # For actual months, use actual data from trial balance
        if year == self.current_year and month <= self.current_month:
            actual = self.get_actual_amount(year, 40010, month)
            if actual != 0:
                return actual
        
        # For forecast months, use IMF forecast input file
        if 'imf_forecast' not in self.data or self.data['imf_forecast'] is None:
            return 0
        
        imf_df = self.data['imf_forecast']
        month_name = self.month_cols[month - 1]  # Jan, Feb, etc.
        col_name = f'{month_name}_{year}_IMF'
        
        if col_name not in imf_df.columns:
            return 0
        
        # Sum all hotels for this month
        total_imf = imf_df[col_name].sum()
        return total_imf if pd.notna(total_imf) else 0

    def calculate_tech_service_fee(self, year, month):
        """Calculate technical service fee - for ALL hotels in Technical_Service_Fees tab"""
        
        # ALWAYS use actual data for historical years and current year actuals
        if year < self.current_year or (year == self.current_year and month <= self.current_month):
            actual = self.get_actual_amount(year, 40020, month)
            if actual != 0:
                return actual
            # If actual is 0, still return 0 (don't calculate from sheet for historical periods)
            else:
                return 0
        
        # For future months, calculate from Technical Service Fees sheet
        total_tech_fee = 0
        month_date = datetime(year, month, 1)
        
        # Only calculate if we have tech service fee data
        if 'tech_service_fees' not in self.data:
            return 0
        
        tech_fees_df = self.data['tech_service_fees']
        
        # Process ALL properties in the tech service fees sheet
        # Not limited to active hotels - these can be standalone tech contracts
        for _, fee_row in tech_fees_df.iterrows():
            property_id = int(fee_row['Property_ID']) if pd.notna(fee_row.get('Property_ID')) else 0
            
            if property_id == 0:
                continue  # Skip invalid entries
            
            # Check if fee is active for this date
            fee_active = True
            
            # Check effective date
            if 'Effective_Date' in fee_row and pd.notna(fee_row['Effective_Date']):
                if month_date < pd.to_datetime(fee_row['Effective_Date']):
                    fee_active = False
            
            # Check end date
            if 'End_Date' in fee_row and pd.notna(fee_row['End_Date']):
                if month_date > pd.to_datetime(fee_row['End_Date']):
                    fee_active = False
            
            # Check Include_Tech_Fee flag if it exists
            if 'Include_Tech_Fee' in fee_row:
                include = str(fee_row['Include_Tech_Fee']).upper()
                if include not in ['YES', 'Y', '1', 'TRUE']:
                    fee_active = False
            
            # Add the fee if active
            if fee_active:
                monthly_fee = 0
                if 'Tech_Service_Fee_Monthly' in fee_row and pd.notna(fee_row['Tech_Service_Fee_Monthly']):
                    monthly_fee = float(fee_row['Tech_Service_Fee_Monthly'])
                total_tech_fee += monthly_fee
        
        # Technical service fees are fixed contracts - no CPI adjustment
        return total_tech_fee

    def calculate_accounting_fee_revenue(self, year, month):
        """Calculate accounting fee revenue including pipeline hotels"""
        if year == self.current_year and month <= self.current_month:
            return self.get_actual_amount(year, 40030, month)
        
        month_date = datetime(year, month, 1)
        active_hotels = self.get_active_hotels(month_date)
        
        if active_hotels.empty:
            return 0
        
        total_accounting_fee = 0
        for _, hotel in active_hotels.iterrows():
            # Use the accounting fee from the data
            monthly_fee = hotel.get('Accounting_Fee_Monthly', 2500)
            if pd.isna(monthly_fee):
                monthly_fee = 2500
            total_accounting_fee += monthly_fee
        
        # Apply CPI for ALL future years
        if year > self.current_year:
            years_diff = year - self.current_year
            total_accounting_fee = total_accounting_fee * (1.03 ** years_diff)
        
        return total_accounting_fee

