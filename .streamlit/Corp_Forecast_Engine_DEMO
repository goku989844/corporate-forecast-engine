    def _process_expense_logic(self):
        """Process expense logic from simplified expenses"""
        if 'expenses' not in self.data:
            return
        
        exp_df = self.data['expenses']
        self.expense_logic = {}
        
        for _, row in exp_df.iterrows():
            gl_code = int(row['GL_Account'])
            
            # Get base values
            expense_type = row.get('Expense_Type', 'Fixed')
            per_hotel = float(row.get('Per_Hotel', 0)) if pd.notna(row.get('Per_Hotel')) else 0
            base_amount = float(row.get('Base_Amount', 0)) if pd.notna(row.get('Base_Amount')) else 0
            per_employee = float(row.get('Per_Employee', 0)) if pd.notna(row.get('Per_Employee')) else 0
            
            # SKIP placeholder rows: blank Expense_Type OR all amounts are zero/blank
            if pd.isna(row.get('Expense_Type')) or expense_type == '':
                print(f"    GL {gl_code}: SKIPPED (blank Expense_Type - placeholder row)")
                continue
            
            if base_amount == 0 and per_hotel == 0 and per_employee == 0:
                # Check if this has any Variable monthly data
                has_monthly_data = False
                for year in [self.current_year, self.current_year + 1, self.current_year + 2]:
                    for month_col in self.month_cols:
                        year_col = f"{month_col}_{year}"
                        if year_col in row.index and pd.notna(row[year_col]) and row[year_col] != 0:
                            has_monthly_data = True
                            break
                    if has_monthly_data:
                        break
                
                if not has_monthly_data:
                    print(f"    GL {gl_code}: SKIPPED (all amounts are zero - placeholder row)")
                    continue
            
            # NEW: Check if this GL code already exists
            if gl_code in self.expense_logic:
                # GL code already exists - ADD to existing amounts
                existing = self.expense_logic[gl_code]
                
                # Add base amounts together
                existing['base_amount'] += base_amount
                
                # For per_hotel and per_employee, add type-specific components
                if expense_type == 'Per_Hotel':
                    existing['per_hotel'] += per_hotel
                elif expense_type == 'Per_Employee':
                    existing['per_employee'] += per_employee
                elif expense_type == 'Mixed':
                    existing['per_hotel'] += per_hotel  # base_amount already added above
                elif expense_type == 'Mixed_Employee':
                    existing['per_employee'] += per_employee  # base_amount already added above
                
                # Keep the same type and CPI rate
                # Process Variable year-specific data if it exists
                if expense_type == 'Variable':
                # FIXED: Use dynamic year range instead of hardcoded years
                    for year in [self.current_year, self.current_year + 1, self.current_year + 2]:
                        year_amounts = {}
                        for month_col in self.month_cols:
                            year_col = f"{month_col}_{year}"
                            if year_col in row.index and pd.notna(row[year_col]):
                                value = float(row[year_col])
                                # Add to existing year amounts
                                if year in existing.get('yearly_amounts', {}):
                                    if month_col in existing['yearly_amounts'][year]:
                                        existing['yearly_amounts'][year][month_col] += value
                                    else:
                                        existing['yearly_amounts'][year][month_col] = value
                                else:
                                    if 'yearly_amounts' not in existing:
                                        existing['yearly_amounts'] = {}
                                    if year not in existing['yearly_amounts']:
                                        existing['yearly_amounts'][year] = {}
                                    existing['yearly_amounts'][year][month_col] = value
                
                print(f"    GL {gl_code}: ADDED to existing (new total base: ${existing['base_amount']:,.2f})")
            
            else:
                # NEW GL code - create new entry
                self.expense_logic[gl_code] = {
                    'type': expense_type,
                    'cpi_rate': float(row.get('Annual_CPI_Increase_Rate', 0.03)) if pd.notna(row.get('Annual_CPI_Increase_Rate')) else 0.03,
                    'per_employee': per_employee,
                    'per_hotel': per_hotel,
                    'base_amount': base_amount,
                    'manual_forecasts': {},
                    'yearly_amounts': {}
                }
                
                # Process Variable expenses with year-specific columns
                if expense_type == 'Variable':
                    for year in [self.current_year, self.current_year + 1, self.current_year + 2]:
                        year_amounts = {}
                        for month_col in self.month_cols:
                            year_col = f"{month_col}_{year}"
                            if year_col in row.index and pd.notna(row[year_col]):
                                year_amounts[month_col] = float(row[year_col])
                        
                        if year_amounts:
                            self.expense_logic[gl_code]['yearly_amounts'][year] = year_amounts
                            print(f"    GL {gl_code}: Loaded {len(year_amounts)} months for {year}")
                
                print(f"    GL {gl_code}: Created with base amount ${base_amount:,.2f}")

