        for month in range(1, 13):
            if grand_totals['revenue'][month] > 0:
                monthly_margin = ((grand_totals['revenue'][month] - grand_totals['expenses'][month]) / grand_totals['revenue'][month])
                margin_row.append(monthly_margin)
            else:
                margin_row.append('')
        
        # Annual margin
        annual_revenue = sum(grand_totals['revenue'].values())
        if annual_revenue > 0:
            annual_margin = (ebitda_total / annual_revenue)
            margin_row.append(annual_margin)
        else:
