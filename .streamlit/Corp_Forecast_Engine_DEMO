    def _check_property_matching(self):
            """Check which properties match between Hotel Master and Revenue Forecast"""
            hotels_df = self.data['hotel_master']
            revenue_df = self.data['hotel_revenue']
            
            # Get active hotels
            active_hotels = hotels_df[hotels_df['Status'] != 'Terminated']['Property_ID'].tolist()
            revenue_properties = revenue_df['Property_ID'].tolist()
            
            # Find matches and mismatches
            self.matching_properties = set(active_hotels) & set(revenue_properties)
            self.missing_revenue_properties = set(active_hotels) - set(revenue_properties)
            
            print(f"    Property Matching: {len(self.matching_properties)} match, {len(self.missing_revenue_properties)} missing revenue")
            if self.missing_revenue_properties:
                print(f"    Missing revenue for: {sorted(self.missing_revenue_properties)}")

