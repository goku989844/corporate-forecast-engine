            margin_row.extend(['', '', ''])
        
        rows.append(margin_row)
        
        # NEW: Add NOI after EBITDA
        rows.append([''] * len(header))
        
        noi_row = ['NET OPERATING INCOME (NOI)']
        noi_total = 0
        noi_budget_total = 0
        noi_prior_total = 0
        
        for month in range(1, 13):
            # Calculate non-operating for this month
            if target_year == self.current_year and month <= self.current_month:
                non_operating_month = sum(self.get_actual_amount(target_year, gl, month)
                                        for gl in self.gl_mapping.get('non_operating', {}).keys())
            else:
                non_operating_month = sum(self.forecast_amount(target_year, gl, month)
                                        for gl in self.gl_mapping.get('non_operating', {}).keys())
            
            # FIXED: NOI calculation
            monthly_noi = (grand_totals['revenue'][month] - 
                        grand_totals['payroll'][month] - 
                        grand_totals['operating'][month] - 
                        non_operating_month -
                        grand_totals['noi_adjustments'][month])
            noi_row.append(monthly_noi)
            noi_total += monthly_noi
            
            # Track budget and prior for NOI if current year
            if target_year == self.current_year:
                # Calculate budget NOI for this month
                month_rev_budget = sum(self.get_budget_amount(gl, self.current_year, month) 
                                    for gl in self.gl_mapping['revenue'].keys())
                month_payroll_budget = sum(self.get_budget_amount(gl, self.current_year, month)
                                        for gl in self.gl_mapping['payroll'].keys())
                month_operating_budget = sum(self.get_budget_amount(gl, self.current_year, month)
                                        for gl in self.gl_mapping['operating'].keys())
                month_non_operating_budget = sum(self.get_budget_amount(gl, self.current_year, month)
                                                for gl in self.gl_mapping['non_operating'].keys())
                month_noi_adj_budget = sum(self.get_budget_amount(gl, self.current_year, month)
                                        for gl in noi_below_ebitda_items)
                
                noi_budget_total += (month_rev_budget - month_payroll_budget - month_operating_budget - 
                                month_non_operating_budget - month_noi_adj_budget)
                
                # Calculate prior NOI for this month
                month_rev_prior = sum(self.get_actual_amount(self.current_year - 1, gl, month)
                                    for gl in self.gl_mapping['revenue'].keys())
                month_payroll_prior = sum(self.get_actual_amount(self.current_year - 1, gl, month)
                                        for gl in self.gl_mapping['payroll'].keys())
                month_operating_prior = sum(self.get_actual_amount(self.current_year - 1, gl, month)
                                        for gl in self.gl_mapping['operating'].keys())
                month_non_operating_prior = sum(self.get_actual_amount(self.current_year - 1, gl, month)
                                            for gl in self.gl_mapping['non_operating'].keys())
                month_noi_adj_prior = sum(self.get_actual_amount(self.current_year - 1, gl, month)
                                        for gl in noi_below_ebitda_items)
                
                noi_prior_total += (month_rev_prior - month_payroll_prior - month_operating_prior - 
                                month_non_operating_prior - month_noi_adj_prior)
        
        noi_row.append(noi_total)
        
        if target_year == self.current_year:
            noi_row.append(noi_budget_total)
            noi_row.append(noi_prior_total)
            noi_yoy = ((noi_total / noi_prior_total) - 1) if noi_prior_total > 0 else 0
            noi_row.append(noi_yoy)
        
        rows.append(noi_row)
        
        # NOI margin row
        noi_margin_row = ['NOI Margin %']
        for month in range(1, 13):
            if grand_totals['revenue'][month] > 0:
                # Recalculate monthly NOI for margin
                if target_year == self.current_year and month <= self.current_month:
                    non_operating_month = sum(self.get_actual_amount(target_year, gl, month)
                                            for gl in self.gl_mapping.get('non_operating', {}).keys())
                else:
                    non_operating_month = sum(self.forecast_amount(target_year, gl, month)
                                            for gl in self.gl_mapping.get('non_operating', {}).keys())
                
                monthly_noi = (grand_totals['revenue'][month] - 
                            grand_totals['payroll'][month] - 
                            grand_totals['operating'][month] - 
                            non_operating_month -
                            grand_totals['noi_adjustments'][month])
                monthly_margin = (monthly_noi / grand_totals['revenue'][month])
                noi_margin_row.append(monthly_margin)
            else:
                noi_margin_row.append('')
        
        # Annual NOI margin
        annual_revenue = sum(grand_totals['revenue'].values())
        if annual_revenue > 0:
            annual_noi_margin = (noi_total / annual_revenue)
            noi_margin_row.append(annual_noi_margin)
        else:
            noi_margin_row.append('')
        
        if target_year == self.current_year:
            noi_margin_row.extend(['', '', ''])
        
        rows.append(noi_margin_row)
        
        return pd.DataFrame(rows[2:], columns=rows[2])

