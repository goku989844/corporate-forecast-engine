        for m in range(1, 13):
            if target_year == self.current_year and m <= self.current_month:
                type_row.append('Actual')
            else:
                type_row.append('Forecast')
        type_row.extend(['', '', '', ''] if target_year == self.current_year else [''])
        rows.append(type_row)
        rows.append([''] * len(header))
        
        grand_totals = {
            'revenue': {m: 0 for m in range(1, 13)},
            'payroll': {m: 0 for m in range(1, 13)},
            'operating': {m: 0 for m in range(1, 13)},
