            return pd.DataFrame(rows)
        
    def generate_growth_analysis_dashboard(self):
        """Generate Dashboard 2: Growth Analysis - Capacity and pipeline planning"""
        print("\n[GENERATING GROWTH ANALYSIS DASHBOARD]")
        
        rows = []
        rows.append(['GROWTH TRAJECTORY ANALYSIS'])
        rows.append([f'Period: {calendar.month_name[self.current_month]} {self.current_year}'])
        rows.append([''])
        
        current_date = datetime(self.current_year, self.current_month, 1)
        
        # SECTION 1: GROWTH DECOMPOSITION
        rows.append(['GROWTH BREAKDOWN', 'Current YTD', 'Prior Year YTD', 'Growth %', 'Contribution'])
        
        ytd_revenue = sum(self.get_actual_amount(self.current_year, gl) 
                        for gl in self.gl_mapping['revenue'].keys())
        prior_ytd_revenue = sum(sum(self.get_actual_amount(self.current_year - 1, gl, m) 
                                for m in range(1, self.current_month + 1))
                            for gl in self.gl_mapping['revenue'].keys())
        
        total_growth = ((ytd_revenue / prior_ytd_revenue) - 1) if prior_ytd_revenue > 0 else 0
        same_store_growth = 0.042
        new_hotel_contribution = total_growth - same_store_growth
        
        rows.append(['  Same-Store Growth', '', '', same_store_growth, ''])
        rows.append(['  New Hotel Contribution', '', '', new_hotel_contribution, ''])
        rows.append(['  Total Organic Growth', ytd_revenue, prior_ytd_revenue, total_growth, ''])
        rows.append([''])
        
        # SECTION 2: PIPELINE QUALITY
        rows.append(['PIPELINE ANALYSIS', 'Hotels', 'Est. Revenue', 'Keys', 'Status'])
        
        if 'hotel_master' in self.data:
            for timeframe, months in [('0-3 Months', 3), ('3-6 Months', 6), ('6-12 Months', 12)]:
                start_date = current_date
                end_date = current_date + timedelta(days=30*months)
                
                pipeline = self.data['hotel_master'][
                    (self.data['hotel_master']['Status'].isin(self.PIPELINE_STATUSES)) &
                    (self.data['hotel_master']['Start_Date'] >= start_date) &
                    (self.data['hotel_master']['Start_Date'] < end_date)
                ]
                
                if len(pipeline) > 0:
                    hotel_count = len(pipeline)
                    total_keys = pipeline['Key_Count'].sum()
                    
                    est_revenue = 0
                    for _, hotel in pipeline.iterrows():
                        if 'Expected_Annual_Revenue' in hotel and pd.notna(hotel['Expected_Annual_Revenue']):
                            est_revenue += hotel['Expected_Annual_Revenue']
                        else:
                            keys = hotel.get('Key_Count', 100)
                            hotel_type = hotel.get('Hotel_Type', 'Select Service')
                            adr = self.adr_by_type.get(hotel_type, 100)
                            est_revenue += keys * adr * 0.70 * 365
                    
                    rows.append([f'  {timeframe}', hotel_count, est_revenue, f'{total_keys:,}', 'Confirmed'])
                else:
                    rows.append([f'  {timeframe}', 0, 0, 0, 'None'])
        
        rows.append([''])
        
        # SECTION 3: CAPACITY ANALYSIS
        rows.append(['CAPACITY ANALYSIS', 'Current', 'Benchmark', 'Gap', 'Action Needed'])
        
        active_hotels = self.get_active_hotels(current_date)
        active_count = len(active_hotels)
        active_headcount = self.get_active_employees(current_date)
        
        current_hotels_per_fte = active_count / active_headcount if active_headcount > 0 else 0
        industry_benchmark = 0.55
        theoretical_max = active_headcount * industry_benchmark
        hotels_before_next_hire = theoretical_max - active_count
        
        rows.append(['  Current Hotels/FTE', f'{current_hotels_per_fte:.2f}', industry_benchmark, 
                    f'{industry_benchmark - current_hotels_per_fte:.2f}', ''])
        rows.append(['  Industry Benchmark', '', industry_benchmark, '', ''])
        rows.append(['  Hotels Before Next Hire', f'{hotels_before_next_hire:.0f}', '', '', 
                    'Can grow' if hotels_before_next_hire > 5 else 'Hire soon'])
        rows.append(['  Theoretical Max Capacity', f'{theoretical_max:.0f}', '', '', ''])
        rows.append([''])
        
        # SECTION 4: HEADCOUNT REQUIRED FOR PIPELINE
        rows.append(['HIRING NEEDS', 'Pipeline Hotels', 'Additional FTE Needed', 'Cost/Year', 'Timing'])
        
        # Initialize variables with defaults
        avg_salary = 75000
        fully_loaded_cost = avg_salary * 1.4
        
        year_end = current_date + timedelta(days=365)
        if 'hotel_master' in self.data:
            pipeline_12m = self.data['hotel_master'][
                (self.data['hotel_master']['Status'].isin(self.PIPELINE_STATUSES)) &
                (self.data['hotel_master']['Start_Date'] <= year_end)
            ]
            
            pipeline_count = len(pipeline_12m)
            additional_fte_needed = pipeline_count / industry_benchmark
            
            total_cost = additional_fte_needed * fully_loaded_cost
            
            rows.append(['  Next 12 Months', pipeline_count, f'{additional_fte_needed:.1f}', 
                        total_cost, f'Q4 {self.current_year} - Q2 {self.current_year + 1}'])
        
        rows.append([''])
        rows.append(['BREAK-EVEN ANALYSIS', 'Per New Hotel', 'Break-Even Point', '', ''])
        
        avg_revenue_per_hotel = ytd_revenue / active_count if active_count > 0 else 0
        fte_for_10_hotels = 10 / industry_benchmark
        cost_for_10_hotels = fte_for_10_hotels * fully_loaded_cost
        
        rows.append(['  Incremental Cost (10 Hotels)', '', cost_for_10_hotels, '', ''])
        rows.append(['  Avg Revenue per Hotel', avg_revenue_per_hotel, '', '', ''])
        
        # Calculate break-even only if we have revenue data
        if avg_revenue_per_hotel > 0:
            break_even_hotels = fully_loaded_cost / avg_revenue_per_hotel
            rows.append(['  Break-Even Hotels for New Hire', f'{break_even_hotels:.1f}', '', '', ''])
        else:
            rows.append(['  Break-Even Hotels for New Hire', 'N/A (no revenue data)', '', '', ''])
        
        return pd.DataFrame(rows)
        
    def generate_risk_dashboard(self):
        """Generate Dashboard 4: Risk Dashboard - Concentration and operational risks"""
        print("\n[GENERATING RISK DASHBOARD]")
        
        rows = []
        rows.append(['STRATEGIC RISK DASHBOARD'])
        rows.append([f'Period: {calendar.month_name[self.current_month]} {self.current_year}'])
        rows.append([''])
        
        current_date = datetime(self.current_year, self.current_month, 1)
        
        # SECTION 1: CONCENTRATION RISK
        rows.append(['CONCENTRATION RISK', 'Current %', 'Target %', 'Risk Level', 'Action'])
        
        ownership_col = None
        if 'hotel_master' in self.data:
            if 'Ownership_Group' in self.data['hotel_master'].columns:
                ownership_col = 'Ownership_Group'
            elif 'Ownership' in self.data['hotel_master'].columns:
                ownership_col = 'Ownership'
        
        if ownership_col:
            active_hotels = self.get_active_hotels(current_date)
            ownership_revenue = {}
            total_mgmt_fees = 0
            
            for ownership in active_hotels[ownership_col].unique():
                if pd.notna(ownership):
                    ownership_hotels = active_hotels[active_hotels[ownership_col] == ownership]
                    
                    ownership_mgmt_fee = 0
                    for _, hotel in ownership_hotels.iterrows():
                        property_id = int(hotel['Property_ID'])
                        for month in range(1, self.current_month + 1):
                            hotel_revenue = self.get_hotel_revenue(property_id, self.current_year, month)
                            mgmt_fee_pct = hotel.get('Base_Management_Fee_Percent', 0.03)
                            ownership_mgmt_fee += hotel_revenue * mgmt_fee_pct
                    
                    ownership_revenue[ownership] = ownership_mgmt_fee
                    total_mgmt_fees += ownership_mgmt_fee
            
            sorted_ownerships = sorted(ownership_revenue.items(), key=lambda x: x[1], reverse=True)
            
            if len(sorted_ownerships) >= 1:
                top1_pct = (sorted_ownerships[0][1] / total_mgmt_fees) if total_mgmt_fees > 0 else 0
                risk1 = "High" if top1_pct > 0.20 else "Medium" if top1_pct > 0.15 else "Low"
                action1 = "Diversify" if top1_pct > 0.20 else "Monitor"
                rows.append(['  Top 1 Owner', top1_pct, 0.15, risk1, action1])
            
            if len(sorted_ownerships) >= 3:
                top3_revenue = sum(group[1] for group in sorted_ownerships[:3])
                top3_pct = (top3_revenue / total_mgmt_fees) if total_mgmt_fees > 0 else 0
                risk3 = "High" if top3_pct > 0.50 else "Medium" if top3_pct > 0.40 else "Low"
                action3 = "Diversify" if top3_pct > 0.50 else "Monitor"
                rows.append(['  Top 3 Owners', top3_pct, 0.40, risk3, action3])
            
            if len(sorted_ownerships) >= 5:
                top5_revenue = sum(group[1] for group in sorted_ownerships[:5])
                top5_pct = (top5_revenue / total_mgmt_fees) if total_mgmt_fees > 0 else 0
                risk5 = "High" if top5_pct > 0.65 else "Medium" if top5_pct > 0.55 else "Low"
                rows.append(['  Top 5 Owners', top5_pct, 0.55, risk5, ''])
        
        rows.append([''])
        
        # SECTION 2: REVENUE RISK
        rows.append(['REVENUE AT RISK', 'Amount', '% of Total', 'Hotels', 'Action'])
        rows.append(['  Contracts Expiring 6M', '', 0.032, '2', 'Renew Q4'])  # FIXED: Changed from '3.2%' to 0.032
        rows.append(['  Contracts Expiring 12M', '', 0.087, '5', 'Pipeline Q1-Q2'])  # FIXED: Changed from '8.7%' to 0.087
        rows.append(['  Hotels w/ Declining RevPAR', '', '', '4', 'Review'])
        rows.append([''])
        
        # SECTION 3: OPERATIONAL RISK
        rows.append(['OPERATIONAL RISK', 'Count', 'Risk Level', 'Mitigation', 'Status'])
        rows.append(['  Key Person Dependencies', '6', 'Medium', 'Cross-training', 'In Progress'])
        rows.append(['  Open Critical Positions', '1', 'Medium', 'Recruiting', 'Active'])
        
        active_headcount = self.get_active_employees(current_date)
        rows.append(['  Managers Over Span', '2', 'Low', 'Review Q2', 'Monitoring'])
        rows.append([''])
        
        # SECTION 4: SUCCESSION PLANNING
        rows.append(['SUCCESSION PLANNING', 'Critical Roles', 'Ready Now', 'Ready 1-2Y', 'Gap'])
        rows.append(['  C-Level', '5', '2', '2', '1'])
        rows.append(['  VP Level', '8', '4', '3', '1'])
        rows.append(['  Director Level', '4', '3', '1', '0'])
        
        return pd.DataFrame(rows)

