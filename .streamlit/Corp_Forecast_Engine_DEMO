    def calculate_payroll_expense(self, year, month, gl_code):
        """Calculate payroll expense for a specific GL code and period"""
        if 'payroll' not in self.data:
            return 0
        
        month_date = datetime(year, month, 1)
        month_end = datetime(year, month, calendar.monthrange(year, month)[1])
        
        payroll = self.data['payroll']
        
        # Base salary GLs (50000-50121)
        if gl_code >= 50000 and gl_code <= 50120:
            total_expense = 0
            for _, emp in payroll.iterrows():
                # Check if this employee's GL matches
                if emp.get('GL_Account') != gl_code:
                    continue
                
                # Check status first - skip if not Active
                status = emp.get('Status', 'Active')
                if pd.notna(status) and str(status).strip().upper() not in ['ACTIVE', '']:
                    continue
                    
                # Check if employee is active in this month
                start_date = pd.to_datetime(emp.get('Start_Date')) if pd.notna(emp.get('Start_Date')) else pd.to_datetime('2000-01-01')
                end_date = pd.to_datetime(emp.get('End_Date')) if pd.notna(emp.get('End_Date')) else pd.to_datetime('2099-12-31')
                
                # Employee must be active for at least part of the month
                if start_date <= month_end and end_date >= month_date:
                    # Get annual salary
                    annual_salary = float(emp.get('Gross_Salary', 0)) if pd.notna(emp.get('Gross_Salary')) else 0
                    
                    # Check for merit increase from payroll file
                    merit_date = pd.to_datetime(emp.get('Merit_Increase_Date')) if pd.notna(emp.get('Merit_Increase_Date')) else None
                    if merit_date and month_date >= merit_date:
                        # Percentage-based merit (applies perpetually from merit date)
                        merit_pct = float(emp.get('Merit_Increase_Percent', 0)) if pd.notna(emp.get('Merit_Increase_Percent')) else 0
                        annual_salary = annual_salary * (1 + merit_pct)
                        
                        # Fixed dollar merit (applies from merit year forward)
                        if year >= merit_date.year:
                            fixed_merit = float(emp.get('Fixed_Merit_Increase_Amount', 0)) if pd.notna(emp.get('Fixed_Merit_Increase_Amount')) else 0
                            annual_salary = annual_salary + fixed_merit
                    
                    # Apply automatic 3% annual merit for future years
                    if year > self.current_year:
                        years_beyond = year - self.current_year
                        annual_merit_rate = 0.03  # 3% annual merit increase
                        annual_salary = annual_salary * ((1 + annual_merit_rate) ** years_beyond)
                    
                    # Calculate monthly amount (considering partial months)
                    if start_date.year == year and start_date.month == month:
                        # Started mid-month
                        days_worked = (month_end - start_date).days + 1
                        days_in_month = calendar.monthrange(year, month)[1]
                        monthly_salary = (annual_salary / 12) * (days_worked / days_in_month)
                    elif end_date.year == year and end_date.month == month:
                        # Ended mid-month
                        days_worked = end_date.day
                        days_in_month = calendar.monthrange(year, month)[1]
                        monthly_salary = (annual_salary / 12) * (days_worked / days_in_month)
                    else:
                        # Full month
                        monthly_salary = annual_salary / 12
                    
                    total_expense += monthly_salary
            return total_expense

