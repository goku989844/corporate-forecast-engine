            if target_year == self.current_year:
                total_row.append(category_budget)
                total_row.append(category_prior)
                yoy_growth = ((category_annual / category_prior) - 1) if category_prior > 0 else 0
                total_row.append(yoy_growth)
            
            rows.append(total_row)
            rows.append([''] * len(header))
        
