                    f'${fy_expenses:,.0f}', f'${prior_expenses:,.0f}', f'{expense_yoy:+.1f}%'])
        
        # EBITDA row
        ebitda_var = ((ytd_ebitda / ytd_budget_ebitda) - 1) * 100 if ytd_budget_ebitda > 0 else 0
        ebitda_yoy = ((ytd_ebitda / prior_ebitda) - 1) * 100 if prior_ebitda > 0 else 0
        rows.append(['EBITDA', f'${current_month_ebitda:,.0f}', f'${ytd_ebitda:,.0f}',
                    f'${ytd_budget_ebitda:,.0f}', f'{ebitda_var:+.1f}%',
                    f'${fy_ebitda:,.0f}', f'${prior_ebitda:,.0f}', f'{ebitda_yoy:+.1f}%'])
        
        # Margin row
        current_margin = (current_month_ebitda / current_month_revenue * 100) if current_month_revenue > 0 else 0
        ytd_margin = (ytd_ebitda / ytd_revenue * 100) if ytd_revenue > 0 else 0
        ytd_budget_margin = (ytd_budget_ebitda / ytd_budget_revenue * 100) if ytd_budget_revenue > 0 else 0
        fy_margin = (fy_ebitda / fy_revenue * 100) if fy_revenue > 0 else 0
        prior_margin = (prior_ebitda / prior_revenue * 100) if prior_revenue > 0 else 0
        
        rows.append(['EBITDA Margin %', f'{current_margin:.1f}%', f'{ytd_margin:.1f}%',
                    f'{ytd_budget_margin:.1f}%', '', f'{fy_margin:.1f}%', 
                    f'{prior_margin:.1f}%', ''])
        
        rows.append([''])
        
        # ========== REMOVED: OPERATIONAL EFFICIENCY METRICS SECTION ==========
        # This section has been removed per user request
        
        # ========== SECTION 2: PORTFOLIO GROWTH ==========
        rows.append(['PORTFOLIO GROWTH METRICS'])
        rows.append(['Period', 'Active Hotels', 'New Additions', 'Total Keys', 'Avg Keys/Hotel'])
        
        # Current
        current_date = datetime(self.current_year, self.current_month, 1)
        year_start = datetime(self.current_year, 1, 1)
        year_end = datetime(self.current_year, 12, 31)
        
        current_hotels = self.get_active_hotels(current_date)
        current_count = len(current_hotels)
        current_keys = current_hotels['Key_Count'].sum() if not current_hotels.empty else 0
        avg_keys = current_keys / current_count if current_count > 0 else 0
        
        # New hotels YTD
        new_ytd = 0
        if 'hotel_master' in self.data:
            new_hotels = self.data['hotel_master'][
                (self.data['hotel_master']['Start_Date'] >= year_start) &
                (self.data['hotel_master']['Start_Date'] <= current_date)
            ]
            new_ytd = len(new_hotels)
        
        rows.append([f'{calendar.month_name[self.current_month][:3]} {self.current_year}', 
                    current_count, f'+{new_ytd}', f'{current_keys:,}', f'{avg_keys:.0f}'])
        
        # Year-end projection
        year_end_hotels = self.get_active_hotels(year_end)
        year_end_count = len(year_end_hotels)
        year_end_keys = year_end_hotels['Key_Count'].sum() if not year_end_hotels.empty else 0
        avg_keys_ye = year_end_keys / year_end_count if year_end_count > 0 else 0
        new_full_year = year_end_count - current_count + new_ytd
        
        rows.append([f'Dec {self.current_year} (Proj)', 
                    year_end_count, f'+{new_full_year}', f'{year_end_keys:,}', f'{avg_keys_ye:.0f}'])
        
        # Next two years
        for year in [self.current_year + 1, self.current_year + 2]:
            future_date = datetime(year, 12, 31)
            future_hotels = self.get_active_hotels(future_date)
            future_count = len(future_hotels)
            future_keys = future_hotels['Key_Count'].sum() if not future_hotels.empty else 0
            avg_keys_future = future_keys / future_count if future_count > 0 else 0
            
            prior_year_end = datetime(year - 1, 12, 31)
            prior_hotels = self.get_active_hotels(prior_year_end)
            prior_count = len(prior_hotels)
            new_in_year = future_count - prior_count
            
            rows.append([f'Dec {year} (Proj)', 
                        future_count, f'+{new_in_year}', f'{future_keys:,}', f'{avg_keys_future:.0f}'])
        
        rows.append([''])
        
        # ========== SECTION 3: REVENUE MIX (FULL YEAR FORECAST) ==========
        rows.append(['REVENUE MIX ANALYSIS'])
        rows.append(['Revenue Stream', 'Full Year Forecast', '% of Total', 'Per Hotel/Month'])
        
        # Calculate full year forecast for each revenue stream (actuals + forecast)
        def get_full_year_amount(gl_code):
            total = 0
            for m in range(1, 13):
                if m <= self.current_month:
                    total += self.get_actual_amount(self.current_year, gl_code, m)
                else:
                    total += self.forecast_amount(self.current_year, gl_code, m)
            return total
        
        # Full year total revenue
        fy_total_revenue = sum(get_full_year_amount(gl) for gl in self.gl_mapping['revenue'].keys())
        
        # Management fees
        mgmt_fee_fy = get_full_year_amount(40000)
        rows.append(['Management Fees', f'${mgmt_fee_fy:,.0f}', 
                    f'{(mgmt_fee_fy/fy_total_revenue*100):.1f}%' if fy_total_revenue > 0 else 'N/A',
                    f'${mgmt_fee_fy/year_end_count/12:,.0f}' if year_end_count > 0 else 'N/A'])
        
        # Accounting fees
        acct_fee_fy = get_full_year_amount(40030)
        rows.append(['Accounting Fees', f'${acct_fee_fy:,.0f}',
                    f'{(acct_fee_fy/fy_total_revenue*100):.1f}%' if fy_total_revenue > 0 else 'N/A',
                    f'${acct_fee_fy/year_end_count/12:,.0f}' if year_end_count > 0 else 'N/A'])
        
        # Revenue Management fees
        rev_mgmt_fy = get_full_year_amount(40040)
        rows.append(['Revenue Mgmt Fees', f'${rev_mgmt_fy:,.0f}',
                    f'{(rev_mgmt_fy/fy_total_revenue*100):.1f}%' if fy_total_revenue > 0 else 'N/A',
                    f'${rev_mgmt_fy/year_end_count/12:,.0f}' if year_end_count > 0 else 'N/A'])
        
        # Technical Service fees
        tech_fee_fy = get_full_year_amount(40020)
        rows.append(['Technical Service Fees', f'${tech_fee_fy:,.0f}',
                    f'{(tech_fee_fy/fy_total_revenue*100):.1f}%' if fy_total_revenue > 0 else 'N/A',
                    f'${tech_fee_fy/year_end_count/12:,.0f}' if year_end_count > 0 else 'N/A'])
        
        # Other revenue
        other_revenue_fy = fy_total_revenue - mgmt_fee_fy - acct_fee_fy - rev_mgmt_fy - tech_fee_fy
        if other_revenue_fy > 0:
            rows.append(['Other Revenue', f'${other_revenue_fy:,.0f}',
                        f'{(other_revenue_fy/fy_total_revenue*100):.1f}%' if fy_total_revenue > 0 else 'N/A',
                        f'${other_revenue_fy/year_end_count/12:,.0f}' if year_end_count > 0 else 'N/A'])
        
            # ========== SECTION 4: OWNERSHIP ANALYSIS BY YEAR (EXPANDED) ==========
            rows.append([''])
            rows.append(['OWNERSHIP & BRAND ANALYSIS - MULTI-YEAR PROJECTION'])
            rows.append([''])

            # Check for both possible column names
            ownership_col = None
            if 'hotel_master' in self.data:
                if 'Ownership_Group' in self.data['hotel_master'].columns:
                    ownership_col = 'Ownership_Group'
                elif 'Ownership' in self.data['hotel_master'].columns:
                    ownership_col = 'Ownership'

            if ownership_col:
                # FIXED: Use dynamic year range
                for year in [self.current_year, self.current_year + 1, self.current_year + 2]:
                    rows.append([f'{year} PROJECTIONS'])
                    rows.append(['Ownership/Brand', 'Hotel Count', 'Total Keys', 'Avg Size', 'Annual Mgmt Fee', 'Fee/Hotel', '% of Total'])
                    
                    # Get active hotels for this year (year-end) for hotel count/keys display
                    year_end_date = datetime(year, 12, 31)
                    active_hotels_df = self.get_active_hotels(year_end_date)
                    
                    # FIXED: Use same calculation as forecast_amount to ensure totals match
                    # Get total management fee for the year using the same method as forecast tabs
                    total_mgmt_fee_for_year = 0
                    for month in range(1, 13):
                        if year == self.current_year and month <= self.current_month:
                            # Use actual data (same as forecast)
                            total_mgmt_fee_for_year += self.get_actual_amount(year, 40000, month)
                        else:
                            # Use forecast calculation (same as forecast)
                            total_mgmt_fee_for_year += self.calculate_management_fee_revenue(year, month)
                    
                    # Calculate ownership SHARES (proportional breakdown)
                    ownership_metrics = {}
                    ownership_calculated_fees = {}
                    total_calculated_fees = 0
                    
                    # Process hotels WITH ownership - calculate shares
                    hotels_with_ownership = active_hotels_df[active_hotels_df[ownership_col].notna()]
                    
                    for ownership in hotels_with_ownership[ownership_col].unique():
                        if pd.notna(ownership):
                            ownership_hotels = hotels_with_ownership[hotels_with_ownership[ownership_col] == ownership]
                            hotel_count = len(ownership_hotels)
                            keys_count = ownership_hotels['Key_Count'].sum()
                            
                            # Calculate this ownership's fee (for proportional share)
                            ownership_calc_fee = 0
                            for month in range(1, 13):
                                month_date = datetime(year, month, 1)
                                month_active_hotels = self.get_active_hotels(month_date)
                                month_ownership_hotels = month_active_hotels[
                                    (month_active_hotels[ownership_col] == ownership) & 
                                    (month_active_hotels[ownership_col].notna())
                                ]
                                
                                for _, hotel in month_ownership_hotels.iterrows():
                                    property_id = int(hotel['Property_ID'])
                                    mgmt_fee_pct = hotel.get('Base_Management_Fee_Percent', 0.03)
                                    if pd.isna(mgmt_fee_pct) or mgmt_fee_pct == 0:
                                        mgmt_fee_pct = 0.03
                                    
                                    if 'Status' in hotel and hotel['Status'] in self.PIPELINE_STATUSES:
                                        if 'Expected_Annual_Revenue' in hotel and pd.notna(hotel['Expected_Annual_Revenue']):
                                            annual_revenue = float(hotel['Expected_Annual_Revenue'])
                                            if year > self.current_year:
                                                years_diff = year - self.current_year
                                                annual_revenue = annual_revenue * (1.03 ** years_diff)
                                            hotel_revenue = annual_revenue / 12
                                        else:
                                            keys = hotel.get('Key_Count', 100)
                                            hotel_type = hotel.get('Hotel_Type', 'Select Service')
                                            adr = self.adr_by_type.get(hotel_type, 100)
                                            occupancy = 0.70
                                            days_in_month = calendar.monthrange(year, month)[1]
                                            hotel_revenue = keys * adr * occupancy * days_in_month
                                            if year > self.current_year:
                                                hotel_revenue = hotel_revenue * (1.03 ** (year - self.current_year))
                                    else:
                                        hotel_revenue = self.get_hotel_revenue(property_id, year, month)
                                        if hotel_revenue == 0:
                                            keys = hotel.get('Key_Count', 100)
                                            adr = 100
                                            occupancy = 0.70
                                            days_in_month = calendar.monthrange(year, month)[1]
                                            hotel_revenue = keys * adr * occupancy * days_in_month
                                            if year > self.current_year:
                                                hotel_revenue = hotel_revenue * (1.03 ** (year - self.current_year))
                                    
                                    ownership_calc_fee += hotel_revenue * mgmt_fee_pct
                            
                            ownership_calculated_fees[ownership] = ownership_calc_fee
                            total_calculated_fees += ownership_calc_fee
                            
                            ownership_metrics[ownership] = {
                                'hotels': hotel_count,
                                'keys': keys_count,
                                'calc_fee': ownership_calc_fee
                            }
                    
                    # Process hotels WITHOUT ownership
                    hotels_without_ownership = active_hotels_df[active_hotels_df[ownership_col].isna()]
                    
                    if len(hotels_without_ownership) > 0:
                        hotel_count = len(hotels_without_ownership)
                        keys_count = hotels_without_ownership['Key_Count'].sum()
                        
                        ownership_calc_fee = 0
                        for month in range(1, 13):
                            month_date = datetime(year, month, 1)
                            month_active_hotels = self.get_active_hotels(month_date)
                            month_no_ownership_hotels = month_active_hotels[month_active_hotels[ownership_col].isna()]
                            
                            for _, hotel in month_no_ownership_hotels.iterrows():
                                property_id = int(hotel['Property_ID'])
                                mgmt_fee_pct = hotel.get('Base_Management_Fee_Percent', 0.03)
                                if pd.isna(mgmt_fee_pct) or mgmt_fee_pct == 0:
                                    mgmt_fee_pct = 0.03
                                
                                if 'Status' in hotel and hotel['Status'] in self.PIPELINE_STATUSES:
                                    if 'Expected_Annual_Revenue' in hotel and pd.notna(hotel['Expected_Annual_Revenue']):
                                        annual_revenue = float(hotel['Expected_Annual_Revenue'])
                                        if year > self.current_year:
                                            annual_revenue = annual_revenue * (1.03 ** (year - self.current_year))
                                        hotel_revenue = annual_revenue / 12
                                    else:
                                        keys = hotel.get('Key_Count', 100)
                                        hotel_type = hotel.get('Hotel_Type', 'Select Service')
                                        adr = self.adr_by_type.get(hotel_type, 100)
                                        occupancy = 0.70
                                        days_in_month = calendar.monthrange(year, month)[1]
                                        hotel_revenue = keys * adr * occupancy * days_in_month
                                        if year > self.current_year:
                                            hotel_revenue = hotel_revenue * (1.03 ** (year - self.current_year))
                                else:
                                    hotel_revenue = self.get_hotel_revenue(property_id, year, month)
                                    if hotel_revenue == 0:
                                        keys = hotel.get('Key_Count', 100)
                                        adr = 100
                                        occupancy = 0.70
                                        days_in_month = calendar.monthrange(year, month)[1]
                                        hotel_revenue = keys * adr * occupancy * days_in_month
                                        if year > self.current_year:
                                            hotel_revenue = hotel_revenue * (1.03 ** (year - self.current_year))
                                
                                ownership_calc_fee += hotel_revenue * mgmt_fee_pct
                        
                        ownership_calculated_fees['[Ownership Not Specified]'] = ownership_calc_fee
                        total_calculated_fees += ownership_calc_fee
                        
                        ownership_metrics['[Ownership Not Specified]'] = {
                            'hotels': hotel_count,
                            'keys': keys_count,
                            'calc_fee': ownership_calc_fee
                        }
                    
                    # FIXED: Scale ownership fees proportionally to match forecast total
                    # This ensures KPI total matches the forecast tab total exactly
                    for ownership in ownership_metrics:
                        calc_fee = ownership_metrics[ownership]['calc_fee']
                        if total_calculated_fees > 0:
                            share = calc_fee / total_calculated_fees
                            scaled_fee = share * total_mgmt_fee_for_year
                        else:
                            scaled_fee = 0
                        
                        ownership_metrics[ownership]['mgmt_fee'] = scaled_fee
                        ownership_metrics[ownership]['per_hotel'] = scaled_fee / ownership_metrics[ownership]['hotels'] if ownership_metrics[ownership]['hotels'] > 0 else 0
                    
                    total_mgmt_fees_year = total_mgmt_fee_for_year
                    
                    # Sort by management fee (largest first)
                    sorted_ownerships = sorted(ownership_metrics.items(), 
                                            key=lambda x: x[1]['mgmt_fee'], 
                                            reverse=True)
                    
                    # CHANGED: Display ALL ownership groups (not just top 10)
                    rows.append([f'Showing all {len(sorted_ownerships)} ownership groups:', '', '', '', '', '', ''])
                    
                    for ownership, metrics in sorted_ownerships:  # Display ALL groups
                        pct_of_total = (metrics['mgmt_fee'] / total_mgmt_fees_year) if total_mgmt_fees_year > 0 else 0
                        avg_hotel_size = metrics['keys'] / metrics['hotels'] if metrics['hotels'] > 0 else 0
                        
                        rows.append([
                            ownership[:25] if isinstance(ownership, str) else str(ownership)[:25],
                            metrics['hotels'],
                            metrics['keys'],
                            avg_hotel_size,
                            metrics['mgmt_fee'],
                            metrics['per_hotel'],
                            pct_of_total
                        ])
                    
                    # Add total row for this year
                    total_hotels = len(active_hotels_df)
                    total_keys = active_hotels_df['Key_Count'].sum() if not active_hotels_df.empty else 0
                    
                    rows.append(['TOTAL', 
                                total_hotels,
                                total_keys,
                                total_keys/total_hotels if total_hotels > 0 else 0,
                                total_mgmt_fees_year,
                                total_mgmt_fees_year/total_hotels if total_hotels > 0 else 0,
                                1.0])
                    
                    rows.append([''])  # Blank row between years
        

                
                # ========== SECTION 5: CONCENTRATION RISK (Current Year Only) ==========
                rows.append([''])
                rows.append([f'CONCENTRATION RISK ANALYSIS - {self.current_year}'])
                rows.append(['Metric', 'Value', 'Risk Level'])
                
                # Calculate concentration for current year
                current_date = datetime(self.current_year, self.current_month, 1)
                active_hotels_current = self.get_active_hotels(current_date)
                
                ownership_metrics_current = {}
                total_mgmt_fees_current = 0
                
                for ownership in active_hotels_current[ownership_col].unique():
                    if pd.notna(ownership):
                        ownership_hotels = active_hotels_current[active_hotels_current[ownership_col] == ownership]
                        
                        ownership_mgmt_fee = 0
                        for _, hotel in ownership_hotels.iterrows():
                            property_id = int(hotel['Property_ID'])
                            for month in range(1, self.current_month + 1):
                                hotel_revenue = self.get_hotel_revenue(property_id, self.current_year, month)
                                mgmt_fee_pct = hotel.get('Base_Management_Fee_Percent', 0.03)
                                ownership_mgmt_fee += hotel_revenue * mgmt_fee_pct
                        
                        ownership_metrics_current[ownership] = ownership_mgmt_fee
                        total_mgmt_fees_current += ownership_mgmt_fee
                
                sorted_ownerships_current = sorted(ownership_metrics_current.items(), 
                                                key=lambda x: x[1], 
                                                reverse=True)
                
                if sorted_ownerships_current:
                    # Top 1 concentration
                    if len(sorted_ownerships_current) >= 1:
                        top1_pct = (sorted_ownerships_current[0][1] / total_mgmt_fees_current) if total_mgmt_fees_current > 0 else 0
                        risk1 = "High" if top1_pct > 0.30 else "Medium" if top1_pct > 0.20 else "Low"
                        rows.append([f'Top 1 Ownership Revenue %', top1_pct, risk1])
                    
                    # Top 3 concentration
                    if len(sorted_ownerships_current) >= 3:
                        top3_revenue = sum(group[1] for group in sorted_ownerships_current[:3])
                        top3_pct = (top3_revenue / total_mgmt_fees_current) if total_mgmt_fees_current > 0 else 0
                        risk3 = "High" if top3_pct > 0.60 else "Medium" if top3_pct > 0.45 else "Low"
                        rows.append([f'Top 3 Ownership Revenue %', top3_pct, risk3])
                    
                    # Top 5 concentration
                    if len(sorted_ownerships_current) >= 5:
                        top5_revenue = sum(group[1] for group in sorted_ownerships_current[:5])
                        top5_pct = (top5_revenue / total_mgmt_fees_current) if total_mgmt_fees_current > 0 else 0
                        risk5 = "High" if top5_pct > 0.75 else "Medium" if top5_pct > 0.60 else "Low"
                        rows.append([f'Top 5 Ownership Revenue %', top5_pct, risk5])
            
            else:
                # No ownership data available
                rows.append([f'Ownership data not available (no Ownership column found)', '', '', '', '', '', ''])
                rows.append(['Please add an "Ownership" or "Ownership_Group" column to Hotel Master Data', '', '', '', '', '', ''])
        
            return pd.DataFrame(rows)  # ← End of generate_key_metrics

    def generate_executive_scorecard(self):
            """Generate Dashboard 1: Executive Scorecard - One-page monthly KPI view"""
            print("\n[GENERATING EXECUTIVE SCORECARD]")
            
            rows = []
            rows.append(['EXECUTIVE SCORECARD'])
            rows.append([f'Period: {calendar.month_name[self.current_month]} {self.current_year}'])
            rows.append([''])
            
            current_date = datetime(self.current_year, self.current_month, 1)
            
            # SECTION 1: FINANCIAL PERFORMANCE
            rows.append(['FINANCIAL PERFORMANCE', 'Current Month', 'YTD', 'vs Budget', 'vs Prior Year'])
            
            current_month_revenue = sum(self.get_actual_amount(self.current_year, gl, self.current_month) 
                                        for gl in self.gl_mapping['revenue'].keys())
            ytd_revenue = sum(self.get_actual_amount(self.current_year, gl) 
                            for gl in self.gl_mapping['revenue'].keys())
            ytd_budget_revenue = sum(self.get_budget_amount(gl, self.current_year) 
                                    for gl in self.gl_mapping['revenue'].keys())
            prior_ytd_revenue = sum(sum(self.get_actual_amount(self.current_year - 1, gl, m) 
                                    for m in range(1, self.current_month + 1))
                                for gl in self.gl_mapping['revenue'].keys())
            
            revenue_vs_budget = ((ytd_revenue / ytd_budget_revenue) - 1) if ytd_budget_revenue > 0 else 0
            revenue_vs_prior = ((ytd_revenue / prior_ytd_revenue) - 1) if prior_ytd_revenue > 0 else 0
            
            rows.append(['  Revenue', current_month_revenue, ytd_revenue, revenue_vs_budget, revenue_vs_prior])
            
            current_month_expenses = sum(self.get_actual_amount(self.current_year, gl, self.current_month)
                                        for section in ['payroll', 'operating', 'non_operating']
                                        for gl in self.gl_mapping[section].keys())
            ytd_expenses = sum(self.get_actual_amount(self.current_year, gl)
                            for section in ['payroll', 'operating', 'non_operating']
                            for gl in self.gl_mapping[section].keys())
            
            current_month_ebitda = current_month_revenue - current_month_expenses
            ytd_ebitda = ytd_revenue - ytd_expenses
            ebitda_margin = (ytd_ebitda / ytd_revenue) if ytd_revenue > 0 else 0
            
            rows.append(['  EBITDA', current_month_ebitda, ytd_ebitda, '', ''])
            rows.append(['  EBITDA Margin %', '', ebitda_margin, '', ''])
            
            active_headcount = self.get_active_employees(current_date)
            revenue_per_employee = ytd_revenue / active_headcount if active_headcount > 0 else 0
            
            rows.append(['  Revenue per Employee', '', revenue_per_employee, '', ''])
            rows.append([''])
            
            # SECTION 2: PORTFOLIO METRICS
            rows.append(['PORTFOLIO METRICS', 'Current', 'Year-End Proj', 'Change', 'Pipeline'])
            
            active_hotels = self.get_active_hotels(current_date)
            active_count = len(active_hotels)
            active_keys = active_hotels['Key_Count'].sum() if not active_hotels.empty else 0
            
            year_end_date = datetime(self.current_year, 12, 31)
            year_end_hotels = self.get_active_hotels(year_end_date)
            year_end_count = len(year_end_hotels)
            
            change = year_end_count - active_count
            
            if 'hotel_master' in self.data:
                pipeline = self.data['hotel_master'][
                    self.data['hotel_master']['Status'].isin(self.PIPELINE_STATUSES)
                ]
                pipeline_count = len(pipeline)
            else:
                pipeline_count = 0
            
            rows.append(['  Active Hotels', active_count, year_end_count, f'+{change}', pipeline_count])
            rows.append(['  Total Keys', f'{active_keys:,}', '', '', ''])
            rows.append(['  Revenue at Risk (12M)', '', 0.082, '', ''])  # FIXED: Changed from '8.2%' to 0.082
            rows.append([''])
            
            # SECTION 3: EFFICIENCY METRICS
            rows.append(['EFFICIENCY METRICS', 'Current', 'Target', 'vs Target', 'Trend'])
            
            hotels_per_fte = active_count / active_headcount if active_headcount > 0 else 0
            target_hotels_per_fte = 0.55
